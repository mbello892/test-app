# ============================================
# Environment Variables — Generated by Scaffold
# ============================================
#
# Copy this file to .env.local:
#   cp .env.example .env.local
#
# Then fill in the values below.
# DO NOT commit .env.local to git.

# ---- Supabase ----
# Get these from: supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=          # Starts with https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # The "anon public" key
SUPABASE_SERVICE_ROLE_KEY=         # The "service_role" key (keep secret)

# ---- Auth ----
# Auth is handled by Supabase. Enable providers in:
# supabase.com/dashboard → your project → Authentication → Providers

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
